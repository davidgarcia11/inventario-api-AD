    {
      "name": "1b. Almacenes V2 (via Apiman)",
      "description": "Operaciones V2 de Almacén pasando por el gateway. Demuestra que la nueva versión también queda protegida por la API Key y el rate limit que Apiman aplica al plan.",
      "item": [
        {
          "name": "POST crear almacén V2 prioritario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
