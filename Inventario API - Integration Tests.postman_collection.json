            },
            "description": ""
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('DELETE devuelve 204', function () {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "pm.test('El cuerpo de la respuesta está vacío', function () {",
                  "    pm.expect(pm.response.text()).to.eql('');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
