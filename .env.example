# Plantilla de variables de entorno para docker compose up.
# Copia este fichero a .env y ajusta los valores antes de levantar el stack.

# Perfil de Spring con el que arranca el contenedor de la API.
# Valores admitidos: docker (por defecto), dev, prod.
#   - docker: ddl-auto=update, sin datos de muestra (el que corre en AWS).
#   - dev:    ddl-auto=create-drop + DataSeederConfig carga 3 almacenes
#             cada arranque. Pensado para enseñar la diferencia entre
#             perfiles sin parar el contenedor.
#   - prod:   ddl-auto=validate, sin datos. Si el esquema no coincide
#             con las entidades, la app no arranca.
SPRING_PROFILE=docker

# Contraseña del usuario root de MariaDB (solo para el contenedor)
DB_ROOT_PASSWORD=cambiame_root

# Nombre de la base de datos que se creará al arrancar el contenedor
DB_NAME=inventario_db

# Usuario y contraseña de la aplicación (los usa la API para conectarse)
DB_USERNAME=inventario
DB_PASSWORD=cambiame_app

# Clave secreta en Base64 para firmar los tokens JWT.
# Generar una nueva con: openssl rand -base64 32
JWT_SECRET=Y2FtYmlhbWVfanc=

