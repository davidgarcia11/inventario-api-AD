    {
      "name": "3. GET - Filtrar por Nombre y Precio (Query Params)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8081/api/productos?nombre=Taladro&precioVenta=100",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "productos"
          ],
          "query": [
            {
              "key": "nombre",
              "value": "Taladro",
              "description": "Debe contener 'Taladro'"
            },
            {
              "key": "precioVenta",
              "value": "100",
              "description": "Debe ser igual a 100"
            }
          ]
        },
        "description": "Prueba clave: WireMock detecta los parámetros de la URL y devuelve un resultado filtrado específico."
      },
      "response": []
    },
    {
      "name": "4. POST - Crear Producto (201 Created)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"nombre\": \"Nuevo Producto\",\n    \"sku\": \"NUEVO-001\",\n    \"precioVenta\": 25.50,\n    \"stockTotal\": 50\n}"
        },
        "url": {
          "raw": "http://localhost:8081/api/productos",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "productos"
          ]
        },
        "description": "Simula una creación exitosa. Devuelve 201 y el Location header."
      },
      "response": []
    },
    {
      "name": "5. POST - Crear con Error (400 Bad Request)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"nombre\": \"ERROR_DATOS\",\n    \"sku\": \"\",\n    \"mensaje\": \"Este body fuerza el error 400\"\n}"
        },
        "url": {
          "raw": "http://localhost:8081/api/productos",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "productos"
          ]
        },
        "description": "Al enviar la palabra clave 'ERROR_DATOS' en el body, WireMock simula un fallo de validación."
      },
      "response": []
    },
