                "v2",
                "almacenes"
              ]
            },
            "description": "Crea un almacén V2 marcado como prioritario. Guarda el id devuelto en {{almacenPrioritarioId}} para que el DELETE de más abajo pueda usarlo.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Almacén Apiman Prioritario\",\n  \"ubicacion\": \"Zaragoza\",\n  \"capacidadMaxima\": 5000,\n  \"stockActual\": 0,\n  \"responsable\": \"Defensa via Apiman\",\n  \"prioritario\": true\n}"
            }
          },
          "response": [],
          "event": [
