{
  "info": {
    "_postman_id": "wm-profesor-check",
    "name": "WireMock - TODAS LAS PRUEBAS",
    "description": "Colección completa para demostrar al profesor todos los verbos y filtros.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. GET - Listar Todos",
      "request": { "method": "GET", "url": "http://localhost:8081/api/productos" }
    },
    {
      "name": "2. GET - Por ID (Existe)",
      "request": { "method": "GET", "url": "http://localhost:8081/api/productos/1" }
    },
    {
      "name": "3. GET - CON FILTROS (Importante)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8081/api/productos?nombre=Taladro&precioVenta=100",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "8081",
          "path": [ "api", "productos" ],
          "query": [
            { "key": "nombre", "value": "Taladro" },
            { "key": "precioVenta", "value": "100" }
          ]
        },
        "description": "Simula la búsqueda filtrada exacta que pide el Wiremock"
      }
    },
    {
      "name": "4. POST - Crear (201 OK)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\"nombre\": \"Bien\"}" },
        "url": "http://localhost:8081/api/productos"
      }
    },
    {
      "name": "5. POST - Crear (400 Bad Request)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\"nombre\": \"ERROR_DATOS\"}" },
        "url": "http://localhost:8081/api/productos",
        "description": "Al enviar el texto ERROR_DATOS en el body, Wiremock devuelve 400"
      }
    },
    {
      "name": "6. PUT - Actualizar Total",
      "request": { "method": "PUT", "url": "http://localhost:8081/api/productos/1" }
    },
    {
      "name": "7. PATCH - Actualizar Parcial",
      "request": { "method": "PATCH", "url": "http://localhost:8081/api/productos/1" }
    },
    {
      "name": "8. DELETE - Borrar (204)",
      "request": { "method": "DELETE", "url": "http://localhost:8081/api/productos/1" }
    },
    {
      "name": "9. GET - Error 404 (No existe)",
      "request": { "method": "GET", "url": "http://localhost:8081/api/productos/999" }
    },
    {
      "name": "10. GET - Error 500 (Servidor)",
      "request": { "method": "GET", "url": "http://localhost:8081/api/productos/500" }
    }
  ]
}