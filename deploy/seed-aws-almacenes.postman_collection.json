        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Almacén Crítico Madrid\",\n  \"ubicacion\": \"Mercamadrid, Madrid\",\n  \"capacidadMaxima\": 15000,\n  \"stockActual\": 12000,\n  \"responsable\": \"Carlos Ruiz\",\n  \"prioritario\": true\n}"
