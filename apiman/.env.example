APIMAN_HOSTNAME=local.gd

APIMAN_GATEWAY_MANAGEMENT_PORT=8081
# Puerto en el HOST para acceder a Apiman (Traefik). Cambiado del 8080 original
# para no chocar con la Inventario API.
HTTP_PORT=7080

# URLs públicas (las ve el navegador). Apuntan a los puertos host
# donde cada servicio queda expuesto en el docker-compose adaptado:
#   - Manager UI  → localhost:7080
#   - Gateway     → localhost:7081
#   - Keycloak    → localhost:7082
APIMAN_GATEWAY_PUBLIC_ENDPOINT=http://localhost:7081
APIMAN_MANAGER_UI_ENDPOINT=http://localhost:7080/apimanui/api-manager/
APIMAN_MANAGER_API_ENDPOINT=http://localhost:7080/apiman
KEYCLOAK_PUBLIC_ENDPOINT=http://localhost:7082
# URL interna (la usan los servicios entre sí dentro de Docker)
KEYCLOAK_PRIVATE_ENDPOINT=http://keycloak:8080

# Estos placeholders los reemplaza setup.java en el primer arranque
# con secretos aleatorios y un par de claves RSA. Ejecuta:
#   docker compose -f docker-compose.setup.yml up
# antes del primer docker compose up.
KEYCLOAK_APIMAN_API_SECRET=REPLACE_THIS_SECRET
KEYCLOAK_APIMAN_UI_SECRET=REPLACE_THIS_SECRET
KEYCLOAK_GATEWAY_SECRET=REPLACE_THIS_SECRET
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin123!
KEYCLOAK_REALM=apiman
KEYCLOAK_REALM_CERTIFICATE=
KEYCLOAK_REALM_PRIVATE_KEY=
KEYCLOAK_REALM_PUBLIC_KEY=

POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=admin123!
POSTGRES_KEYCLOAK_DATABASE=keycloak
POSTGRES_KEYCLOAK_USER=keycloak
POSTGRES_KEYCLOAK_PASSWORD=admin123!

ELASTICSEARCH_JAVA_MEMORY=1g
ELASTICSEARCH_PROTOCOL=http
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

SELF_SIGNED=true

# No modificar, lo usa docker compose internamente
COMPOSE_PROJECT_NAME=apiman

MAX_CACHE_SIZE_IN_MB=100
